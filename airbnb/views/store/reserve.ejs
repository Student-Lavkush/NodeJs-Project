<%- include('../partials/head') %>
  </head>
  <body>
    <%- include('../partials/nav') %>
    <main class="container mx-auto bg-white shadow-lg rounded-lg p-8 mt-10 max-w-xl">
      <h2 class="text-3xl text-red-500 font-bold text-center mb-6">
        Here are our registered homes:
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <% registeredHomes.forEach(home => { %>
          <div class="bg-white border border-gray-200 rounded-lg shadow-lg overflow-hidden hover:shadow-xl transition duration-300 transform hover:scale-105">
            <% if (home.photo) { %>
              <img src="<%= home.photo %>" alt="<%= home.houseName %>" class="w-full h-48 object-cover">
            <% } %>
            <div class="p-6">
              <h3 class="text-2xl font-bold text-gray-800 mb-2"><%= home.houseName %></h3>
              <p class="text-gray-600 mb-3 flex items-center">
                <span class="font-semibold mr-2">Location:</span><%= home.location %>
              </p>
              <p class="text-gray-600 mb-3 flex items-center">
                <span class="font-semibold mr-2">Price:</span><span class="text-green-600 text-lg font-bold">$<%= home.price %></span>
              </p>
              <p class="text-gray-600 flex items-center">
                <span class="font-semibold mr-2">Rating:</span><span class="text-yellow-500 text-lg">★ <%= home.rating %></span>
              </p>
            </div>
          </div>
        <% }) %>
      </div>
    </main>
  </body>
</html>