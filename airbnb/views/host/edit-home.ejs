<%- include('../partials/head') %>
</head>
<body>
  <%- include('../partials/nav') %>

  <main class="container mx-auto mt-8 p-8 bg-white rounded-lg shadow-md">
    <h1 class="text-3xl font-bold mb-6 text-center text-gray-800">
      <%= editing ? "Edit" : "Register" %> Your Home on AirBnB
    </h1>

    <form action="/host/<%= editing ? 'edit-home' : 'add-home' %>" method="POST" class="max-w-md mx-auto" enctype="multipart/form-data">

      <% if (editing) { %>
        <input type="hidden" name="id" value="<%= home._id %>" />
      <% } %>

      <input
        type="text"
        name="houseName"
        value="<%= editing ? home.houseName : '' %>"
        placeholder="Enter your House Name"
        class="w-full px-4 py-2 mb-4 border rounded-md focus:outline-none focus:ring-2 focus:ring-red-500"
      />

      <input
        type="number"
        name="price"
        value="<%= editing ? home.price : '' %>"
        placeholder="Enter the price for per night"
        class="w-full px-4 py-2 mb-4 border rounded-md focus:outline-none focus:ring-2 focus:ring-red-500"
      />

      <input
        type="text"
        name="location"
        value="<%= editing ? home.location : '' %>"
        placeholder="Location"
        class="w-full px-4 py-2 mb-4 border rounded-md focus:outline-none focus:ring-2 focus:ring-red-500"
      />

      <input
        type="number"
        name="rating"
        value="<%= editing ? home.rating : '' %>"
        placeholder="Rating"
        class="w-full px-4 py-2 mb-4 border rounded-md focus:outline-none focus:ring-2 focus:ring-red-500"
      />

      <label class="block mb-1 font-medium text-gray-700">
  Upload House Photo
</label>

<input
  type="file"
  name="photo"
  accept="image/jpg,image/jpeg,image/png"
  class="w-full px-4 py-2 mb-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-red-500"
/>

<p class="text-sm text-gray-500 mb-4">
  Upload clear image of your house (JPG, JPEG, PNG)
</p>

     



      <textarea
        name="description"
        placeholder="Describe your home"
        class="w-full px-4 py-2 mb-4 border rounded-md focus:outline-none focus:ring-2 focus:ring-red-500"
      ><%= editing ? home.description : '' %></textarea>

      <input
        type="submit"
        value="<%= editing ? 'Update Home' : 'Add Home' %>"
        class="w-full bg-red-500 text-white py-2 rounded-md hover:bg-red-600 transition duration-300"
      />

    </form>
  </main>
</body>
</html>