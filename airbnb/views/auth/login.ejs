<%- include('../partials/head') %>
  </head>
  <body>
    <%- include('../partials/nav') %>

    <main class="relative min-h-screen bg-gradient-to-br from-blue-50 via-indigo-50 to-purple-50 py-8 md:py-12 px-4 overflow-hidden flex items-center justify-center">
      <!-- Decorative background elements -->
      <div class="absolute top-0 left-0 w-96 h-96 bg-blue-200 rounded-full mix-blend-multiply filter blur-3xl opacity-20 animate-pulse"></div>
      <div class="absolute bottom-0 right-0 w-96 h-96 bg-purple-200 rounded-full mix-blend-multiply filter blur-3xl opacity-20 animate-pulse" style="animation-delay: 2s"></div>
      <div class="absolute top-1/2 left-1/3 w-80 h-80 bg-indigo-200 rounded-full mix-blend-multiply filter blur-3xl opacity-20 animate-pulse" style="animation-delay: 4s"></div>

      <section class="relative w-full max-w-2xl rounded-3xl border border-gray-200/50 bg-white/95 backdrop-blur-xl shadow-2xl shadow-blue-200/50 overflow-hidden">
        <!-- Decorative top border gradient -->
        <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-blue-500 via-indigo-500 to-purple-500"></div>

        <div class="bg-gradient-to-br from-blue-50 via-indigo-50 to-purple-50 p-8 md:p-10 border-b border-gray-100 relative">
          <!-- Decorative corner accents -->
          <div class="absolute top-4 right-4 w-20 h-20 bg-blue-100 rounded-full opacity-30 blur-2xl"></div>
          <div class="absolute bottom-4 left-4 w-24 h-24 bg-purple-100 rounded-full opacity-30 blur-2xl"></div>

          <div class="text-center relative z-10">
            <p class="text-xs md:text-sm font-bold text-gray-400 uppercase tracking-[0.3em] mb-3 letter-spacing">Welcome to the platform</p>
            
            <div class="my-4 inline-flex h-16 md:h-20 w-16 md:w-20 items-center justify-center rounded-full bg-gradient-to-br from-blue-400 via-indigo-400 to-purple-400 shadow-2xl shadow-blue-300/50 animate-bounce">
              <span class="text-4xl md:text-5xl">🏠</span>
            </div>

            <h2 class="text-3xl md:text-4xl font-black bg-gradient-to-r from-blue-600 via-indigo-600 to-purple-600 bg-clip-text text-transparent mb-1 tracking-tight">
              Airbnb
            </h2>

            <div class="flex items-center justify-center gap-2 mb-4">
              <div class="h-1 w-6 bg-gradient-to-r from-blue-500 to-indigo-500 rounded-full"></div>
              <p class="text-base md:text-lg uppercase tracking-[0.3em] font-bold bg-gradient-to-r from-blue-500 via-indigo-600 to-purple-600 bg-clip-text text-transparent">Welcome Back</p>
              <div class="h-1 w-6 bg-gradient-to-r from-indigo-500 to-purple-500 rounded-full"></div>
            </div>

            <h1 class="text-4xl md:text-5xl font-black bg-gradient-to-r from-indigo-600 to-blue-500 bg-clip-text text-transparent mb-2 tracking-tight">
              Log in
            </h1>

            <p class="text-sm md:text-base leading-relaxed text-gray-700 font-medium max-w-md mx-auto">
              Unlock exclusive access to your bookings, favorites, and hosted homes
            </p>
          </div>
        </div>

        <form action="/login" method="POST" class="space-y-4 p-8 md:p-10">
          <%- include('../partials/errors')%>

          <div class="group">
            <label for="username" class="mb-2 block text-xs md:text-sm font-bold text-gray-800 flex items-center gap-2">
              <span class="text-lg">📧</span>
              Email or Username
            </label>
            <div class="relative">
              <input
                id="username"
                type="email"
                name="email"
                placeholder="you@example.com"
                value ="<%= oldInput.email?oldInput.email:''%>"
                class="w-full rounded-2xl border-2 border-gray-200 bg-gray-50/50 px-4 py-3 md:px-5 md:py-4 text-gray-900 placeholder-gray-400 shadow-sm text-sm md:text-base transition duration-300 focus:border-indigo-500 focus:bg-white focus:outline-none focus:ring-4 focus:ring-indigo-100 hover:border-indigo-300"
                required
              />
            </div>
          </div>

          <div class="group">
            <label for="password" class="mb-2 block text-xs md:text-sm font-bold text-gray-800 flex items-center gap-2">
              <span class="text-lg">🔐</span>
              Password
            </label>
            <div class="relative">
              <input
                id="password"
                type="password"
                name="password"
                placeholder="••••••••••"
                class="w-full rounded-2xl border-2 border-gray-200 bg-gray-50/50 px-4 py-3 md:px-5 md:py-4 text-gray-900 placeholder-gray-400 shadow-sm text-sm md:text-base transition duration-300 focus:border-indigo-500 focus:bg-white focus:outline-none focus:ring-4 focus:ring-indigo-100 hover:border-indigo-300"
                required
              />
            </div>
          </div>

          <button type="submit" class="group relative w-full overflow-hidden rounded-2xl bg-gradient-to-r from-blue-500 via-indigo-500 to-purple-500 px-6 py-3 md:py-4 text-sm md:text-base font-bold text-white shadow-lg shadow-blue-300/50 transition duration-300 hover:shadow-2xl hover:shadow-blue-400/50 hover:scale-105 focus:outline-none focus:ring-4 focus:ring-blue-200">
            <div class="absolute inset-0 bg-gradient-to-r from-blue-600 via-indigo-600 to-purple-600 opacity-0 group-hover:opacity-100 transition duration-300"></div>
            <span class="relative flex items-center justify-center gap-2">
              <span>🚀</span>
              Log in
            </span>
          </button>

          <div class="relative my-4 md:my-6">
            <div class="absolute inset-0 flex items-center">
              <div class="w-full border-t border-gray-200"></div>
            </div>
            <div class="relative flex justify-center text-xs md:text-sm">
              <span class="bg-white px-4 text-gray-500 font-medium">or</span>
            </div>
          </div>

          <p class="text-center text-sm md:text-base text-gray-700">
            New to Airbnb?
            <a href="/signup" class="font-bold bg-gradient-to-r from-blue-600 to-indigo-600 bg-clip-text text-transparent hover:from-indigo-600 hover:to-purple-600 transition duration-300 underline decoration-2 underline-offset-2">
              Create an account
            </a>
          </p>
        </form>
      </section>
    </main>
  </body>
</html>