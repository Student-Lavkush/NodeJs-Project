<%- include('../partials/head') %>
  </head>
  <body>
    <%- include('../partials/nav') %>

    <main class="min-h-screen bg-gray-100 py-12">
      <section class="mx-auto w-full max-w-2xl rounded-3xl border border-gray-200 bg-white p-10 shadow-2xl shadow-gray-200/80">
        <div class="mb-8 text-center">
          <p class="text-sm uppercase tracking-[0.35em] text-red-500">Create your account</p>
          <h1 class="mt-3 text-4xl font-bold text-gray-900">Sign up to join the community</h1>
          <p class="mt-3 text-gray-500">Fast, secure, and easy registration for hosts and guests.</p>
        </div>

        <form action="/signup" method="POST" class="space-y-5">
         <%- include('../partials/errors')%>
          <div class="grid gap-5 sm:grid-cols-2">
            <div>
              <label for="firstName" class="mb-2 block text-sm font-medium text-gray-700">First Name</label>
              <input
                id="firstName"
                type="text"
                name="firstName"
                value ="<%= oldInput.firstName?oldInput.firstName:''%>"
                placeholder="John"
                class="w-full rounded-2xl border border-gray-200 bg-gray-50 px-4 py-3 text-gray-900 shadow-sm transition focus:border-red-400 focus:bg-white focus:outline-none focus:ring-2 focus:ring-red-100"
                required
              />
            </div>

            <div>
              <label for="lastName" class="mb-2 block text-sm font-medium text-gray-700">Last Name</label>
              <input
                id="lastName"
                type="text"
                name="lastName"
                value ="<%= oldInput.lastName?oldInput.lastName:''%>"
                placeholder="Doe"
                class="w-full rounded-2xl border border-gray-200 bg-gray-50 px-4 py-3 text-gray-900 shadow-sm transition focus:border-red-400 focus:bg-white focus:outline-none focus:ring-2 focus:ring-red-100"
              />
            </div>
          </div>

          <div>
            <label for="email" class="mb-2 block text-sm font-medium text-gray-700">Email Address</label>
            <input
              id="email"
              type="email"
              name="email"
              placeholder="you@example.com"
              value ="<%= oldInput.email?oldInput.email:''%>"
              class="w-full rounded-2xl border border-gray-200 bg-gray-50 px-4 py-3 text-gray-900 shadow-sm transition focus:border-red-400 focus:bg-white focus:outline-none focus:ring-2 focus:ring-red-100"
            />
          </div>

          <div class="grid gap-5 sm:grid-cols-2">
            <div>
              <label for="password" class="mb-2 block text-sm font-medium text-gray-700">Password</label>
              <input
                id="password"
                type="password"
                name="password"
                placeholder="Enter a strong password"
                class="w-full rounded-2xl border border-gray-200 bg-gray-50 px-4 py-3 text-gray-900 shadow-sm transition focus:border-red-400 focus:bg-white focus:outline-none focus:ring-2 focus:ring-red-100"
                required
              />
            </div>

            <div>
              <label for="confirmPassword" class="mb-2 block text-sm font-medium text-gray-700">Confirm Password</label>
              <input
                id="confirmPassword"
                type="password"
                name="confirmPassword"
                placeholder="Confirm your password"
                class="w-full rounded-2xl border border-gray-200 bg-gray-50 px-4 py-3 text-gray-900 shadow-sm transition focus:border-red-400 focus:bg-white focus:outline-none focus:ring-2 focus:ring-red-100"
              />
            </div>
          </div>

          <fieldset class="rounded-2xl border border-gray-200 bg-gray-50 p-5">
            <legend class="px-1 text-sm font-semibold text-gray-700">Choose your role</legend>
            <div class="mt-4 flex flex-wrap gap-4">
              <label class="inline-flex cursor-pointer items-center gap-2 rounded-full border border-gray-200 bg-white px-4 py-3 text-gray-700 shadow-sm transition hover:border-red-300">
                <input type="radio" name="usertype" value="guest" id="guest" class="h-4 w-4 text-red-500" <%= oldInput && oldInput.usertype === 'guest' ? 'checked' : (!oldInput || !oldInput.usertype ? 'checked' : '') %> />
                Guest
              </label>
              <label class="inline-flex cursor-pointer items-center gap-2 rounded-full border border-gray-200 bg-white px-4 py-3 text-gray-700 shadow-sm transition hover:border-red-300">
                <input type="radio" name="usertype" value="host" id="host" class="h-4 w-4 text-red-500" <%= oldInput && oldInput.usertype === 'host' ? 'checked' : '' %> />
                Host
              </label>
            </div>
          </fieldset>

          <div class="flex items-start gap-3">
            <input type="checkbox" name="terms" id="terms" class="mt-1 h-4 w-4 rounded border-gray-300 text-red-500 focus:ring-red-400" <%= oldInput && oldInput.terms ? 'checked' : '' %> required />
            <label for="terms" class="text-sm leading-6 text-gray-600">I agree to the terms and conditions.</label>
          </div>

          <button type="submit" class="w-full rounded-2xl bg-red-500 px-6 py-3 text-base font-semibold text-white shadow-lg shadow-red-500/10 transition hover:bg-red-600 focus:outline-none focus:ring-2 focus:ring-red-200">
            Create account
          </button>

          <p class="mt-4 text-center text-sm text-gray-600">
            Already have an account?
            <a href="/login" class="font-semibold text-red-500 hover:text-red-600">Log in</a>
          </p>
        </form>
      </section>
    </main>
  </body>
</html>