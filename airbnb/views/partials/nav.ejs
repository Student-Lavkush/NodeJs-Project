<header class="sticky top-0 z-50 bg-gradient-to-r from-blue-600 via-indigo-600 to-purple-600 shadow-xl">
  <nav class="container mx-auto px-4 py-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between">
      <!-- Brand -->
      <a href="/" class="text-2xl font-bold text-white px-4 py-2 rounded-lg transition duration-300 hover:bg-white/20 hover:shadow-lg hover:shadow-blue-300/50 hover:scale-105">
        🏠 Airbnb
      </a>

      <!-- Main Navigation -->
      <ul class="hidden md:flex items-center space-x-1">
        <% if(isLoggedIn){ %>
        <li>
          <a
            href="/"
            class="<%= currentPage === 'Index' ? 'bg-white/30 text-white shadow-lg' : 'text-blue-50 hover:bg-white/25 hover:text-white hover:shadow-lg' %> px-4 py-2 rounded-lg font-medium transition duration-300 hover:scale-105">
            Home
          </a>
        </li>
        <%if(user && user.usertype === 'guest'){%>
        <li>
          <a
            href="/homes"
            class="<%= currentPage === 'Home' ? 'bg-white/30 text-white shadow-lg' : 'text-blue-50 hover:bg-white/25 hover:text-white hover:shadow-lg' %> px-4 py-2 rounded-lg font-medium transition duration-300 hover:scale-105">
            Explore
          </a>
        </li>

        <li>
          <a
            href="/favourites"
            class="<%= currentPage === 'Favourites' ? 'bg-white/30 text-white shadow-lg' : 'text-blue-50 hover:bg-white/25 hover:text-white hover:shadow-lg' %> px-4 py-2 rounded-lg font-medium transition duration-300 hover:scale-105">
            Favorites
          </a>
        </li>

        <li>
          <a
            href="/bookings"
            class="<%= currentPage === 'Bookings' ? 'bg-white/30 text-white shadow-lg' : 'text-blue-50 hover:bg-white/25 hover:text-white hover:shadow-lg' %> px-4 py-2 rounded-lg font-medium transition duration-300 hover:scale-105">
            Bookings
          </a>
        </li>
       <%}else{%>
        <li>
          <a
            href="/host/host-home-list"
            class="<%= currentPage === 'Host-homes' ? 'bg-white/30 text-white shadow-lg' : 'text-blue-50 hover:bg-white/25 hover:text-white hover:shadow-lg' %> px-4 py-2 rounded-lg font-medium transition duration-300 hover:scale-105">
            Host Homes
          </a>
        </li>

        <li>
          <a
            href="/host/add-home"
            class="<%= currentPage === 'addHome' ? 'bg-white/30 text-white shadow-lg' : 'text-blue-50 hover:bg-white/25 hover:text-white hover:shadow-lg' %> px-4 py-2 rounded-lg font-medium transition duration-300 hover:scale-105">
            Add Home
          </a>
        </li>
        <%}%>
        <% } %>
      </ul>

      <!-- Auth Buttons -->
      <div class="flex items-center gap-3">
        <% if(!isLoggedIn){ %>
        <a
          href="/login"
          class="text-white font-bold px-6 py-2 rounded-xl bg-blue-500/40 border-2 border-blue-300/60 shadow-md transition duration-300 hover:bg-blue-300/80 hover:border-white hover:text-white hover:shadow-xl hover:shadow-blue-300/60 hover:scale-110">
          Log in
        </a>
        <a
          href="/signup"
          class="bg-white text-blue-600 font-bold px-6 py-2 rounded-xl border-2 border-white shadow-lg transition duration-300 hover:bg-blue-600 hover:text-white hover:border-blue-400 hover:shadow-2xl hover:shadow-blue-400/60 hover:scale-110">
          Sign up
        </a>
        <% } %>

        <% if(isLoggedIn){ %>
        <form action="/logout" method="post" class="inline">
          <button
            type="submit"
            class="bg-white text-blue-600 font-bold px-6 py-2 rounded-xl border-2 border-white shadow-lg transition duration-300 hover:bg-blue-600 hover:text-white hover:border-blue-400 hover:shadow-2xl hover:shadow-blue-400/60 hover:scale-110 cursor-pointer">
            Log out
          </button>
        </form>
        <% } %>
      </div>
    </div>
  </nav>
</header>